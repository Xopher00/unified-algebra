"""Experimental recursion schemes over polynomial functor signatures.

This layer is intentionally above ``morphisms.py`` and ``realize.py``.  It uses
polynomial functor bodies as one-layer signatures and builds self-referential
Hydra primitives for folds and unfolds.

The API is not yet as hardened as the morphism/functor core.  Keep behavior
tests close to any future changes.
"""

from __future__ import annotations

from dataclasses import dataclass

import hydra.core as C
import hydra.dsl.terms as Terms
import hydra.lib.maps as Maps
import hydra.reduction as R
from hydra.core import Name, TypeScheme, TypeVariable
from hydra.dsl.python import Just, Nothing, Right
from hydra.graph import Primitive
from hydra.phantoms import TTerm

from . import actions
from . import realize
from . import expressions
from . import morphisms
from . import functors
from hydra.core import Type, TypeList, TypeMaybe

_DUMMY_SCHEME = TypeScheme((), TypeVariable(Name("a")), Maps.empty())
_EITHER = C.Name("hydra.core.Either")


class AlgebraError(TypeError):
    """Raised when an algebra or coalgebra does not match its signature."""


@dataclass(frozen=True)
class Inductive:
    """Descriptor for a recursive type generated by a polynomial functor.

    ``template(element)`` returns the one-layer functor.  ``mu`` and ``nu``
    produce initial/final carrier types.  ``unroll`` and ``roll`` convert
    between concrete Hydra carriers and their one-layer representation.
    """
    name: str
    template: object   # Callable[[Type], Functor]
    mu: object         # Callable[[Type], Type]  — initial algebra carrier
    nu: object         # Callable[[Type], Type]  — final coalgebra carrier
    unroll: object     # Callable[[Term], TermInject]
    roll: object       # Callable[[TermInject], Term]


# --- roll / unroll for List ---

def _list_unroll(t):
    if not t.value:
        return C.TermInject(C.Injection(_EITHER, C.Field(C.Name("left"), C.TermUnit())))
    return C.TermInject(C.Injection(_EITHER, C.Field(
        C.Name("right"), C.TermPair((t.value[0], C.TermList(t.value[1:])))
    )))


def _list_roll(ti):
    f = ti.value.field
    if f.name.value == "left":
        return C.TermList(())
    return C.TermList((f.term.value[0],) + f.term.value[1].value)


# --- roll / unroll for Maybe ---

def _maybe_unroll(t):
    match t.value:
        case Nothing():
            return C.TermInject(C.Injection(_EITHER, C.Field(C.Name("left"), C.TermUnit())))
        case Just(val):
            return C.TermInject(C.Injection(_EITHER, C.Field(C.Name("right"), val)))


def _maybe_roll(ti):
    f = ti.value.field
    if f.name.value == "left":
        return C.TermMaybe(Nothing())
    return C.TermMaybe(Just(f.term))


# --- standard Inductive descriptors ---

LIST_IND = Inductive(
    name="List",
    template=lambda B: functors.Functor("List", expressions.Sum(expressions.One(), expressions.Prod(expressions.Const(B), expressions.Id()))),
    mu=lambda B: TypeList(B),
    nu=lambda B: TypeList(B),
    unroll=_list_unroll,
    roll=_list_roll,
)

MAYBE_IND = Inductive(
    name="Maybe",
    template=lambda B: functors.Functor("Maybe", expressions.Sum(expressions.One(), expressions.Const(B))),
    mu=lambda B: TypeMaybe(B),
    nu=lambda B: TypeMaybe(B),
    unroll=_maybe_unroll,
    roll=_maybe_roll,
)


# --- core recursive binding ---

def rec(dom: Type, cod: Type, build_impl) -> morphisms.Morphism:
    """Create a recursive morphism as a self-referential Hydra primitive.

    ``build_impl`` receives the primitive name and returns a Hydra primitive
    implementation.  That implementation may recurse by reducing an application
    of ``TermVariable(prim_name)``.
    """
    prim_name = Name(f"unialg.rec.{id(build_impl)}")
    impl = build_impl(prim_name)
    prim = Primitive(prim_name, _DUMMY_SCHEME, impl)
    return morphisms.Morphism(node=expressions.Prim(C.TermVariable(prim_name), dom, cod), aux_primitives=(prim,))


# --- cata and ana ---

def cata(F: Inductive, element: Type, carrier: Type, algebra: morphisms.Morphism) -> morphisms.Morphism:
    """Build a catamorphism from an algebra ``F(carrier) -> carrier``.

    Current limitation: the algebra must be plain, not parametric or lax.
    """
    if algebra.param != C.TypeUnit() or algebra.monad is not None:
        raise AlgebraError("cata currently requires a plain algebra")
    body = F.template(element).body
    expected_dom = functors.apply_poly(body, carrier)
    if morphisms.dom_of(algebra.node) != expected_dom:
        raise AlgebraError(f"algebra.dom must be {expected_dom!r}, got {morphisms.dom_of(algebra.node)!r}")
    if morphisms.cod_of(algebra.node) != carrier:
        raise AlgebraError(f"algebra.cod must be {carrier!r}, got {morphisms.cod_of(algebra.node)!r}")

    alg_term = realize.realize(algebra.node)
    unroll_fn = F.unroll

    def build_impl(prim_name):
        fmap_self = actions._poly_map_term(body, TTerm(C.TermVariable(prim_name))).value
        def impl(ctx, graph, args):
            unrolled = unroll_fn(args[0])
            r = R.reduce_term(ctx, graph, True, Terms.apply(fmap_self, unrolled))
            if not isinstance(r, Right): return r
            return R.reduce_term(ctx, graph, True, Terms.apply(alg_term, r.value))
        return impl

    m = rec(F.mu(element), carrier, build_impl)
    return morphisms.Morphism(node=m.node, aux_primitives=m.aux_primitives + algebra.aux_primitives)


def ana(F: Inductive, element: Type, carrier: Type, coalgebra: morphisms.Morphism) -> morphisms.Morphism:
    """Build an anamorphism from a coalgebra ``carrier -> F(carrier)``.

    Current limitation: the coalgebra must be plain, not parametric or lax.
    """
    if coalgebra.param != C.TypeUnit() or coalgebra.monad is not None:
        raise AlgebraError("ana currently requires a plain coalgebra")
    body = F.template(element).body
    expected_cod = functors.apply_poly(body, carrier)
    if morphisms.dom_of(coalgebra.node) != carrier:
        raise AlgebraError(f"coalgebra.dom must be {carrier!r}, got {morphisms.dom_of(coalgebra.node)!r}")
    if morphisms.cod_of(coalgebra.node) != expected_cod:
        raise AlgebraError(f"coalgebra.cod must be {expected_cod!r}, got {morphisms.cod_of(coalgebra.node)!r}")

    coalg_term = realize.realize(coalgebra.node)
    roll_fn = F.roll

    def build_impl(prim_name):
        fmap_self = actions._poly_map_term(body, TTerm(C.TermVariable(prim_name))).value
        def impl(ctx, graph, args):
            r = R.reduce_term(ctx, graph, True, Terms.apply(coalg_term, args[0]))
            if not isinstance(r, Right): return r
            r2 = R.reduce_term(ctx, graph, True, Terms.apply(fmap_self, r.value))
            if not isinstance(r2, Right): return r2
            return Right(roll_fn(r2.value))
        return impl

    m = rec(carrier, F.nu(element), build_impl)
    return morphisms.Morphism(node=m.node, aux_primitives=m.aux_primitives + coalgebra.aux_primitives)
