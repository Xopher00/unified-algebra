    "softplus":         {"kind": "unary", "path": "jax.nn.softplus",                      "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.logaddexp": {"kind": "reduce", "path": "jax.scipy.special.logsumexp",         "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "reduce.add":       {"kind": "reduce", "path": "jax.numpy.sum",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.multiply":  {"kind": "reduce", "path": "jax.numpy.prod",                      "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.minimum":   {"kind": "reduce", "path": "jax.numpy.min",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.maximum":   {"kind": "reduce", "path": "jax.numpy.max",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "equal":            {"kind": "elementwise binary", "path": "jax.numpy.equal",         "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "greater":          {"kind": "elementwise binary", "path": "jax.numpy.greater",       "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "less":             {"kind": "elementwise binary", "path": "jax.numpy.less",          "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "and":              {"kind": "elementwise binary", "path": "jax.numpy.logical_and",   "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "or":               {"kind": "elementwise binary", "path": "jax.numpy.logical_or",    "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "clip":             {"kind": "ternary", "path": "jax.numpy.clip",                     "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "where":            {"kind": "ternary", "path": "jax.numpy.where",                    "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "matmul":           {"kind": "contraction", "path": "jax.numpy.matmul",               "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "norm":             {"kind": "reduce", "path": "jax.numpy.linalg.norm",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.and":       {"kind": "reduce", "path": "jax.numpy.all",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.or":        {"kind": "reduce", "path": "jax.numpy.any",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "mean":             {"kind": "reduce", "path": "jax.numpy.mean",                      "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "std":              {"kind": "reduce", "path": "jax.numpy.std",                       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"}
  }
}
