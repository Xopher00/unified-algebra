    "square":           {"kind": "unary", "path": "jax.numpy.square",                     "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sin":              {"kind": "unary", "path": "jax.numpy.sin",                        "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "cos":              {"kind": "unary", "path": "jax.numpy.cos",                        "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "neg":              {"kind": "unary", "path": "jax.numpy.negative",                   "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "bessel_i0":        {"kind": "unary", "path": "jax.scipy.special.i0",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "ceil":             {"kind": "unary", "path": "jax.numpy.ceil",                       "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
