{
  "backend": "numpy",
  "binary_adapter": {"dump": "numpy.save", "load": "numpy.load", "dump_style": "file_first"},
  "structural": {
    "expand_dims": "numpy.expand_dims",
    "transpose": "numpy.transpose",
    "take_diagonal": "numpy.diagonal"
  },
  "operations": {
    "add":              {"kind": "elementwise binary", "path": "numpy.add",               "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "subtract":         {"kind": "elementwise binary", "path": "numpy.subtract",          "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "multiply":         {"kind": "elementwise binary", "path": "numpy.multiply",          "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "divide":           {"kind": "elementwise binary", "path": "numpy.divide",            "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "power":            {"kind": "elementwise binary", "path": "numpy.power",             "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "minimum":          {"kind": "elementwise binary", "path": "numpy.minimum",           "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "maximum":          {"kind": "elementwise binary", "path": "numpy.maximum",           "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "logaddexp":        {"kind": "elementwise binary", "path": "numpy.logaddexp",         "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},

    "tanh":             {"kind": "unary", "path": "numpy.tanh",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "exp":              {"kind": "unary", "path": "numpy.exp",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log":              {"kind": "unary", "path": "numpy.log",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log1p":            {"kind": "unary", "path": "numpy.log1p",                          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sqrt":             {"kind": "unary", "path": "numpy.sqrt",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "abs":              {"kind": "unary", "path": "numpy.abs",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reciprocal":       {"kind": "unary", "path": "numpy.reciprocal",                     "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sign":             {"kind": "unary", "path": "numpy.sign",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "square":           {"kind": "unary", "path": "numpy.square",                         "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sin":              {"kind": "unary", "path": "numpy.sin",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "cos":              {"kind": "unary", "path": "numpy.cos",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "neg":              {"kind": "unary", "path": "numpy.negative",                       "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "bessel_i0":        {"kind": "unary", "path": "scipy.special.i0",                     "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "ceil":             {"kind": "unary", "path": "numpy.ceil",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "digamma":          {"kind": "unary", "path": "scipy.special.digamma",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erf":              {"kind": "unary", "path": "scipy.special.erf",                    "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erfc":             {"kind": "unary", "path": "scipy.special.erfc",                   "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "floor":            {"kind": "unary", "path": "numpy.floor",                          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "lgamma":           {"kind": "unary", "path": "scipy.special.gammaln",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "not":              {"kind": "unary", "path": "numpy.logical_not",                    "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "round":            {"kind": "unary", "path": "numpy.round",                          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},

    "sigmoid":          {"kind": "unary", "path": "scipy.special.expit",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "softmax":          {"kind": "unary", "path": "scipy.special.softmax",                "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "softplus":         {"kind": "unary", "path": "scipy.special.softplus",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.logaddexp": {"kind": "reduce", "path": "scipy.special.logsumexp",             "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "reduce.add":       {"kind": "reduce", "path": "numpy.sum",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.multiply":  {"kind": "reduce", "path": "numpy.prod",                          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.minimum":   {"kind": "reduce", "path": "numpy.min",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.maximum":   {"kind": "reduce", "path": "numpy.max",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "equal":            {"kind": "elementwise binary", "path": "numpy.equal",             "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "greater":          {"kind": "elementwise binary", "path": "numpy.greater",           "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "less":             {"kind": "elementwise binary", "path": "numpy.less",              "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "and":              {"kind": "elementwise binary", "path": "numpy.logical_and",       "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "or":               {"kind": "elementwise binary", "path": "numpy.logical_or",        "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "clip":             {"kind": "ternary", "path": "numpy.clip",                         "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "where":            {"kind": "ternary", "path": "numpy.where",                        "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "matmul":           {"kind": "contraction", "path": "numpy.matmul",                   "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "norm":             {"kind": "reduce", "path": "numpy.linalg.norm",                   "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.and":       {"kind": "reduce", "path": "numpy.all",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.or":        {"kind": "reduce", "path": "numpy.any",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "mean":             {"kind": "reduce", "path": "numpy.mean",                          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "std":              {"kind": "reduce", "path": "numpy.std",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"}
  }
}
