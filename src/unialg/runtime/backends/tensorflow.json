{
  "backend": "tensorflow",
  "binary_adapter": {"dump": "numpy.save", "load": "numpy.load", "dump_style": "file_first"},
  "structural": {
    "expand_dims": "tensorflow.expand_dims",
    "transpose": "tensorflow.transpose",
    "take_diagonal": "tensorflow.experimental.numpy.diagonal"
  },
  "operations": {
    "add":              {"kind": "elementwise binary", "path": "tensorflow.math.add",                    "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "subtract":         {"kind": "elementwise binary", "path": "tensorflow.math.subtract",               "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "multiply":         {"kind": "elementwise binary", "path": "tensorflow.math.multiply",               "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "divide":           {"kind": "elementwise binary", "path": "tensorflow.math.divide",                 "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "power":            {"kind": "elementwise binary", "path": "tensorflow.math.pow",                    "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "minimum":          {"kind": "elementwise binary", "path": "tensorflow.math.minimum",                "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "maximum":          {"kind": "elementwise binary", "path": "tensorflow.math.maximum",                "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "logaddexp":        {"kind": "elementwise binary", "path": "tensorflow.experimental.numpy.logaddexp", "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},

    "tanh":             {"kind": "unary", "path": "tensorflow.math.tanh",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "exp":              {"kind": "unary", "path": "tensorflow.math.exp",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log":              {"kind": "unary", "path": "tensorflow.math.log",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log1p":            {"kind": "unary", "path": "tensorflow.math.log1p",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sqrt":             {"kind": "unary", "path": "tensorflow.math.sqrt",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "abs":              {"kind": "unary", "path": "tensorflow.math.abs",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reciprocal":       {"kind": "unary", "path": "tensorflow.math.reciprocal",           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sign":             {"kind": "unary", "path": "tensorflow.math.sign",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "square":           {"kind": "unary", "path": "tensorflow.math.square",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sin":              {"kind": "unary", "path": "tensorflow.math.sin",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "cos":              {"kind": "unary", "path": "tensorflow.math.cos",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "neg":              {"kind": "unary", "path": "tensorflow.math.negative",             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "bessel_i0":        {"kind": "unary", "path": "tensorflow.math.bessel_i0",            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "ceil":             {"kind": "unary", "path": "tensorflow.math.ceil",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "digamma":          {"kind": "unary", "path": "tensorflow.math.digamma",              "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erf":              {"kind": "unary", "path": "tensorflow.math.erf",                  "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erfc":             {"kind": "unary", "path": "tensorflow.math.erfc",                 "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "floor":            {"kind": "unary", "path": "tensorflow.math.floor",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "lgamma":           {"kind": "unary", "path": "tensorflow.math.lgamma",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "not":              {"kind": "unary", "path": "tensorflow.math.logical_not",          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "round":            {"kind": "unary", "path": "tensorflow.math.round",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},

    "relu":             {"kind": "unary", "path": "tensorflow.nn.relu",                   "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sigmoid":          {"kind": "unary", "path": "tensorflow.nn.sigmoid",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "softmax":          {"kind": "unary", "path": "tensorflow.nn.softmax",                "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "softplus":         {"kind": "unary", "path": "tensorflow.nn.softplus",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.logaddexp": {"kind": "reduce", "path": "tensorflow.math.reduce_logsumexp",    "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "reduce.add":       {"kind": "reduce", "path": "tensorflow.math.reduce_sum",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.multiply":  {"kind": "reduce", "path": "tensorflow.math.reduce_prod",         "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.minimum":   {"kind": "reduce", "path": "tensorflow.math.reduce_min",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.maximum":   {"kind": "reduce", "path": "tensorflow.math.reduce_max",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "equal":            {"kind": "elementwise binary", "path": "tensorflow.math.equal",   "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "greater":          {"kind": "elementwise binary", "path": "tensorflow.math.greater", "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "less":             {"kind": "elementwise binary", "path": "tensorflow.math.less",    "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "and":              {"kind": "elementwise binary", "path": "tensorflow.math.logical_and", "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "or":               {"kind": "elementwise binary", "path": "tensorflow.math.logical_or",  "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "clip":             {"kind": "ternary", "path": "tensorflow.clip_by_value",           "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "where":            {"kind": "ternary", "path": "tensorflow.where",                   "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "matmul":           {"kind": "contraction", "path": "tensorflow.linalg.matmul",       "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "norm":             {"kind": "reduce", "path": "tensorflow.norm",                     "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.and":       {"kind": "reduce", "path": "tensorflow.math.reduce_all",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.or":        {"kind": "reduce", "path": "tensorflow.math.reduce_any",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "mean":             {"kind": "reduce", "path": "tensorflow.math.reduce_mean",         "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "std":              {"kind": "reduce", "path": "tensorflow.math.reduce_std",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"}
  }
}
