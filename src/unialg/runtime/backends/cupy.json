{
  "backend": "cupy",
  "binary_adapter": {"dump": "cupy.save", "load": "cupy.load", "dump_style": "file_first"},
  "structural": {
    "expand_dims": "cupy.expand_dims",
    "transpose": "cupy.transpose",
    "take_diagonal": "cupy.diagonal"
  },
  "operations": {
    "add":              {"kind": "elementwise binary", "path": "cupy.add",                "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "subtract":         {"kind": "elementwise binary", "path": "cupy.subtract",           "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "multiply":         {"kind": "elementwise binary", "path": "cupy.multiply",           "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "divide":           {"kind": "elementwise binary", "path": "cupy.divide",             "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "power":            {"kind": "elementwise binary", "path": "cupy.power",              "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "minimum":          {"kind": "elementwise binary", "path": "cupy.minimum",            "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "maximum":          {"kind": "elementwise binary", "path": "cupy.maximum",            "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "logaddexp":        {"kind": "elementwise binary", "path": "cupy.logaddexp",          "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},

    "tanh":             {"kind": "unary", "path": "cupy.tanh",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "exp":              {"kind": "unary", "path": "cupy.exp",                             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log":              {"kind": "unary", "path": "cupy.log",                             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "log1p":            {"kind": "unary", "path": "cupy.log1p",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sqrt":             {"kind": "unary", "path": "cupy.sqrt",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "abs":              {"kind": "unary", "path": "cupy.abs",                             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reciprocal":       {"kind": "unary", "path": "cupy.reciprocal",                      "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sign":             {"kind": "unary", "path": "cupy.sign",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "square":           {"kind": "unary", "path": "cupy.square",                          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "sin":              {"kind": "unary", "path": "cupy.sin",                             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "cos":              {"kind": "unary", "path": "cupy.cos",                             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "neg":              {"kind": "unary", "path": "cupy.negative",                        "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "bessel_i0":        {"kind": "unary", "path": "cupyx.scipy.special.i0",               "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "ceil":             {"kind": "unary", "path": "cupy.ceil",                            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "digamma":          {"kind": "unary", "path": "cupyx.scipy.special.digamma",          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erf":              {"kind": "unary", "path": "cupyx.scipy.special.erf",              "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "erfc":             {"kind": "unary", "path": "cupyx.scipy.special.erfc",             "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "floor":            {"kind": "unary", "path": "cupy.floor",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "lgamma":           {"kind": "unary", "path": "cupyx.scipy.special.gammaln",          "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "not":              {"kind": "unary", "path": "cupy.logical_not",                     "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "round":            {"kind": "unary", "path": "cupy.round",                           "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},

    "sigmoid":          {"kind": "unary", "path": "cupyx.scipy.special.expit",            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "softmax":          {"kind": "unary", "path": "cupyx.scipy.special.softmax",          "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.logaddexp": {"kind": "reduce", "path": "cupyx.scipy.special.logsumexp",       "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "reduce.add":       {"kind": "reduce", "path": "cupy.sum",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.multiply":  {"kind": "reduce", "path": "cupy.prod",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.minimum":   {"kind": "reduce", "path": "cupy.min",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.maximum":   {"kind": "reduce", "path": "cupy.max",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},

    "equal":            {"kind": "elementwise binary", "path": "cupy.equal",              "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "greater":          {"kind": "elementwise binary", "path": "cupy.greater",            "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "less":             {"kind": "elementwise binary", "path": "cupy.less",               "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "and":              {"kind": "elementwise binary", "path": "cupy.logical_and",        "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "or":               {"kind": "elementwise binary", "path": "cupy.logical_or",         "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "clip":             {"kind": "ternary", "path": "cupy.clip",                          "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "where":            {"kind": "ternary", "path": "cupy.where",                         "arity": 3, "arg_type": "BINARY", "result_type": "BINARY"},
    "matmul":           {"kind": "contraction", "path": "cupy.matmul",                    "arity": 2, "arg_type": "BINARY", "result_type": "BINARY"},
    "norm":             {"kind": "reduce", "path": "cupy.linalg.norm",                    "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "reduce.and":       {"kind": "reduce", "path": "cupy.all",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "reduce.or":        {"kind": "reduce", "path": "cupy.any",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "mean":             {"kind": "reduce", "path": "cupy.mean",                           "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"},
    "std":              {"kind": "reduce", "path": "cupy.std",                            "arity": 2, "arg_types": ["BINARY", "INT"], "result_type": "BINARY"}
  }
}
