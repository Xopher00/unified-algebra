    "floor":            {"kind": "unary", "path": "jax.numpy.floor",                      "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "lgamma":           {"kind": "unary", "path": "jax.scipy.special.gammaln",            "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
    "not":              {"kind": "unary", "path": "jax.numpy.logical_not",                "arity": 1, "arg_type": "BINARY", "result_type": "BINARY"},
