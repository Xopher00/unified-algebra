{
  "label": "elman_rnn",
  "arm": "A",
  "arch": {
    "class": "Ana",
    "poly_f": {"tag": "Product", "left": {"tag": "KConst"}, "right": {"tag": "Exp", "arg": {"tag": "Hole"}}},
    "monad": null,
    "weight_tying": [],
    "lax": false
  },
  "cell": {
    "params": ["v", "bv", "w", "u", "bh"],
    "bindings": [
      {"name": "lin_vs", "expr": {"tag": "Contraction", "semiring": {"label": "real", "add": "add", "multiply": "multiply", "divide": "divide", "zero": "0.0", "one": "1.0"}, "equation": "oi,i->o", "args": ["v", "s"]}},
      {"name": "out",    "expr": {"tag": "ElemOp", "op": "add", "args": ["lin_vs", "bv"]}},
      {"name": "lin_ws", "expr": {"tag": "Contraction", "semiring": {"label": "real", "add": "add", "multiply": "multiply", "divide": "divide", "zero": "0.0", "one": "1.0"}, "equation": "hi,i->h", "args": ["w", "s"]}},
      {"name": "lin_ux", "expr": {"tag": "Contraction", "semiring": {"label": "real", "add": "add", "multiply": "multiply", "divide": "divide", "zero": "0.0", "one": "1.0"}, "equation": "hi,i->h", "args": ["u", "inp"]}},
      {"name": "sum1",   "expr": {"tag": "ElemOp", "op": "add", "args": ["lin_ws", "lin_ux"]}},
      {"name": "sum2",   "expr": {"tag": "ElemOp", "op": "add", "args": ["sum1", "bh"]}},
      {"name": "h_next", "expr": {"tag": "Activation", "kind": "tanh", "arg": "sum2"}}
    ],
    "result": {
      "tag": "Ana",
      "state_var": "s",
      "input_var": "inp",
      "output_bindings": ["lin_vs", "out"],
      "output": "out",
      "next_state_bindings": ["lin_ws", "lin_ux", "sum1", "sum2", "h_next"],
      "next_state": "h_next"
    }
  },
  "ref": {
    "strength": "single-class",
    "torch": {
      "tag": "SingleClass",
      "class": "torch.nn.RNNCell(inp_size, hidden, nonlinearity=\"tanh\")",
      "kwargs": {}
    },
    "tensorflow": {
      "tag": "SingleClass",
      "class": "tf.keras.layers.SimpleRNNCell(hidden, activation=\"tanh\", use_bias=True, dtype=tf.float64)",
      "kwargs": {}
    },
    "numpy": {"tag": "NumpyOnly", "equation": "manual tanh(W@h + U@x + bh)"}
  }
}
